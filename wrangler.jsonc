{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "laguna-hills-hoa",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "laguna_hills_hoa",
      "database_id": ""
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "JWT_SECRET": "change-me-in-production"
  }
}
