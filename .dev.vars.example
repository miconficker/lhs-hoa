# Local development environment variables
# Copy this file to .dev.vars and fill in your actual values
# DO NOT commit .dev.vars to git (it's in .gitignore)

# JWT Secret for authentication
# Generate a secure random string (at least 32 bytes)
# Use: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-generate-with-openssl

# Environment (development for local)
ENVIRONMENT=development

# CORS allowed origins for local development
ALLOWED_ORIGINS=http://localhost:8788

# Google OAuth credentials
# Get these from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add http://localhost:8788/api/auth/google/callback to your OAuth 2.0 client's Authorized redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8788/api/auth/google/callback
